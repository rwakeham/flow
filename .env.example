# Copy to .env and fill in values before running docker compose up

# PostgreSQL password (used internally between containers)
POSTGRES_PASSWORD=changeme

# Password to log in to the dashboard
FLOW_PASSWORD=mysecretpassword

# Random secret key for signing session cookies
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replacewithsecretrandomhex

# Host port to expose the app on (change if 8000 is already in use)
APP_PORT=8000
